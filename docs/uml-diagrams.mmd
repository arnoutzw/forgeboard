%% === State Diagram ===
stateDiagram-v2
    [*] --> Initializing

    state Initializing {
        [*] --> DetectTheme
        DetectTheme --> SetupSSO
        SetupSSO --> LoadData
        LoadData --> BuildTools
        BuildTools --> BindEvents
        BindEvents --> InitialRender
    }

    InitialRender --> Ready

    state Ready {
        [*] --> SelectTool

        state SelectTool {
            [*] --> SelectMode
            SelectMode --> PanMode : Press H
            PanMode --> SelectMode : Press V
            SelectMode --> DrawMode : Press P
            DrawMode --> SelectMode : Press V
            SelectMode --> ShapeMode : Press R/O/D
            ShapeMode --> SelectMode : Press V
            SelectMode --> LineMode : Press L/A/C
            LineMode --> SelectMode : Press V
            SelectMode --> TextMode : Press T
            SelectMode --> StickyMode : Press S
            SelectMode --> EraserMode : Press E
            EraserMode --> SelectMode : Press V
            SelectMode --> LassoMode : Press Q
            LassoMode --> SelectMode : Press V
        }

        state SelectMode {
            [*] --> Idle
            Idle --> ElementSelected : Click element
            ElementSelected --> Dragging : Drag selected
            Dragging --> ElementSelected : Drop
            ElementSelected --> Resizing : Drag handle
            Resizing --> ElementSelected : Release
            ElementSelected --> Idle : Click empty
            Idle --> RubberBand : Drag empty space
            RubberBand --> MultiSelected : Release
            MultiSelected --> Dragging : Drag selection
            MultiSelected --> Idle : Click empty
            ElementSelected --> Editing : Double-click
            Editing --> ElementSelected : Finish edit
        }

        state DrawMode {
            [*] --> PenIdle
            PenIdle --> Drawing : Pointer down (pen/mouse)
            Drawing --> Drawing : Pointer move (collect points)
            Drawing --> SmoothingStroke : Pointer up
            SmoothingStroke --> PenIdle : Stroke saved to elements
            PenIdle --> Panning : Touch (finger)
            Panning --> PenIdle : Touch end
        }

        state ShapeMode {
            [*] --> ShapeIdle
            ShapeIdle --> ShapeDrawing : Pointer down
            ShapeDrawing --> ShapeDrawing : Pointer move (preview)
            ShapeDrawing --> ShapeCreated : Pointer up (size OK)
            ShapeDrawing --> ShapeIdle : Pointer up (too small)
            ShapeCreated --> ShapeIdle : Element added
        }

        state LineMode {
            [*] --> LineIdle
            LineIdle --> LineDrawing : Pointer down (snap to port)
            LineDrawing --> LineDrawing : Pointer move (snap end port)
            LineDrawing --> LineCreated : Pointer up (length OK)
            LineCreated --> LineIdle : Element added
        }

        state EraserMode {
            [*] --> EraserIdle
            EraserIdle --> Erasing : Click/drag on element
            Erasing --> EraserIdle : Element removed
        }
    }

    state BoardManagement {
        [*] --> SingleBoard
        SingleBoard --> MultipleBoards : Create board
        MultipleBoards --> MultipleBoards : Switch board
        MultipleBoards --> SingleBoard : Delete boards
    }

    state ProjectSync {
        [*] --> LocalOnly
        LocalOnly --> ProjectScoped : SSO + project selected
        ProjectScoped --> LocalOnly : Project deselected
        ProjectScoped --> ProjectScoped : Switch project (save old, load new)

        state ProjectScoped {
            [*] --> LoadingFromFirestore
            LoadingFromFirestore --> LiveSync : Data loaded
            LiveSync --> LiveSync : Remote update via onSnapshot
            LiveSync --> AutoSaving : 2s interval / dirty flag
            AutoSaving --> LiveSync : Saved to Firestore + localStorage
        }
    }

    Ready --> BoardManagement : Board operations
    Ready --> ProjectSync : Auth events

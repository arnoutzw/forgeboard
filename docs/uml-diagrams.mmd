    }

    class Board {
        +string id
        +string name
        +string created
        +string modified
        +Element[] elements
        +Viewport viewport
        +string projectId
    }

    class Viewport {
        +number x
        +number y
        +number zoom
    }

    class Element {
        +string id
        +string type
        +number x
        +number y
        +number width
        +number height
        +number rotation
        +string fill
        +string stroke
        +number strokeWidth
        +string strokeDasharray
        +string text
        +number fontSize
        +string textAlign
        +number opacity
        +boolean locked
        +Port[] ports
        +object metadata
    }

    class RectangleElement {
        +string type = "rectangle"
    }

    class EllipseElement {
        +string type = "ellipse"
    }

    class DiamondElement {
        +string type = "diamond"
    }

    class StickyElement {
        +string type = "sticky"
        +string fill
        +string text
    }

    class TextElement {
        +string type = "text"
        +string text
        +number fontSize
    }

    class LineElement {
        +string type = "line"
        +number x2
        +number y2
    }

    class ArrowElement {
        +string type = "arrow"
        +number x2
        +number y2
    }

    class ConnectorElement {
        +string type = "connector"
        +number x2
        +number y2
        +string routeType
    }

    class FreehandElement {
        +string type = "freehand"
        +StrokePoint[] points
        +string mode
    }

    class ImageElement {
        +string type = "image"
        +string imageData
    }

    class MathElement {
        +string type = "math"
        +string latex
        +number fontSize
    }

    class ChartElement {
        +string type = "chart"
        +ChartConfig chartConfig
        +string imageData
    }

    class TableElement {
        +string type = "table"
        +TableConfig tableConfig
        +string imageData
    }

    class EngineeringBlockElement {
        +string type = "engineering-block"
        +string symbolPath
        +string symbolExtra
        +string symbolLabel
        +boolean symbolCircle
        +string symbolFill
        +string symbolDash
        +number iconScale
    }

    class StrokePoint {
        +number x
        +number y
        +number pressure
    }

    class ChartConfig {
        +string type
        +string[][] data
    }

    class TableConfig {
        +string style
        +string[][] data
    }

    class ToolDefinition {
        +string id
        +string label
        +string key
        +string icon
    }

    class DemoFirestore {
        <<localStorage shim>>
        +collection(name) CollRef
        +doc(path) DocRef
        +batch() Batch
        +runTransaction(fn)
    }

    class BSIThemeBridge {
        <<portal integration>>
        +detectTheme()
        +setupSSO()
        +onThemeChange(callback)
    }

    App "1" *-- "*" Board : manages
    Board "1" *-- "*" Element : contains
    Board "1" *-- "1" Viewport : has
    Element <|-- RectangleElement
    Element <|-- EllipseElement
    Element <|-- DiamondElement
    Element <|-- StickyElement

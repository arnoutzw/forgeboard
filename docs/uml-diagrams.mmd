        +string tool
        +Element[] elements
        +string[] selection
        +object[] undoStack
        +object[] redoStack
        +Viewport viewport
        +number gridSize
        +boolean snapToGrid
        +object dragging
        +object resizing
        +object drawing
        +object rubberBand
        +boolean penPressure
        +number penWidth
        +string penColor
        +number penOpacity
        +string penMode
        +boolean penSmoothing
        +number eraserRadius
        +string shapeFill
        +string shapeStroke
        +number shapeStrokeWidth
        +string shapeStrokeDash
        +string theme
        +object currentUser
        +object ssoUser
        +Project[] projects
        +string activeProjectId
        +boolean isDemo
        +Firestore db
        +Function _firestoreUnsubscribe
        +init()
        +setTool(id)
        +render()
        +saveData()
        +loadData()
        +switchBoard(id)
        +switchProject(projectId)
        +createElement(type, x, y, w, h) Element
        +pushUndo()
        +undo()
        +redo()
        +hitTest(x, y) Element
        +hitResizeHandle(x, y, el) string
        +screenToCanvas(sx, sy) Point

%% === Sequence Diagram — Shape Creation Workflow ===
sequenceDiagram
    participant User
    participant UI as App UI
    participant SVG as SVG Canvas
    participant State as App State
    participant Render as Renderer
    participant LS as localStorage
    participant FS as Firestore

    User->>UI: Select Rectangle tool (press R)
    UI->>State: setTool("rectangle")
    State->>UI: Update cursor to crosshair
    UI->>UI: Show shape panel (fill/stroke/dash options)

    User->>SVG: pointerdown at (x1, y1)
    SVG->>State: onPointerDown(event)
    State->>State: screenToCanvas(clientX, clientY)
    State->>State: snapVal(canvasX), snapVal(canvasY)
    State->>State: drawing = {type:"rectangle", startX, startY, x, y, width:0, height:0}

    loop User drags mouse
        User->>SVG: pointermove
        SVG->>State: onPointerMove(event)
        State->>State: screenToCanvas(clientX, clientY)
        State->>State: Update drawing.x, drawing.y, drawing.width, drawing.height
        State->>Render: renderDrawingPreview()
        Render->>SVG: Draw preview rectangle (dashed outline)
        SVG-->>User: Visual feedback of shape size
    end

    User->>SVG: pointerup
    SVG->>State: onPointerUp(event)

    alt Shape large enough (width > 5 AND height > 5)
        State->>State: pushUndo()
        Note over State: undoStack.push(JSON.stringify(elements))
        State->>State: createElement("rectangle", x, y, w, h)
        Note over State: Returns element with id, fill, stroke,<br/>strokeWidth, dasharray, opacity, locked, ports
        State->>State: elements.push(newElement)
        State->>State: selection = [newElement.id]
        State->>Render: render()
        Render->>SVG: Clear and redraw all elements
        Render->>SVG: Draw selection handles on new element
        State->>State: saveData()
        State->>LS: localStorage.setItem(key, JSON.stringify({boards, activeBoardId}))

        opt Firestore connected
            State->>FS: docRef.set({boards, activeBoardId, updatedAt})
            FS-->>State: Save confirmed
        end

        State-->>User: Shape appears on canvas, selected
    else Shape too small
        State->>State: Discard drawing
        State->>Render: clearOverlay()
    end


%% === Sequence Diagram — Freehand Drawing Workflow ===
sequenceDiagram
    participant User
    participant UI as App UI
    participant DC as Draw Canvas (2D)
    participant SVGCanvas as SVG Canvas
    participant State as App State
    participant Smooth as smoothPoints()

    User->>UI: Select Pen tool (press P)
    UI->>State: setTool("pen")
    State->>UI: Show pen panel (color, width, opacity, mode, pressure, smoothing)
    State->>DC: drawCanvas.style.pointerEvents = "auto"

    User->>DC: pointerdown (stylus/mouse)
    DC->>State: onDrawDown(event)

    alt pointerType === "touch"
        State->>State: _panStart = {clientX, clientY, viewport}
        Note over State: Finger = pan, not draw
    else pointerType === "pen" or "mouse"
        State->>DC: setPointerCapture(pointerId)
        State->>State: screenToCanvas(clientX, clientY)
        State->>State: _currentStroke = {points:[{x,y,pressure}], color, baseWidth, opacity, mode}
    end

    loop User draws (pointermove events)
        User->>DC: pointermove
        DC->>State: onDrawMove(event)
        State->>State: screenToCanvas(clientX, clientY)
        State->>State: _currentStroke.points.push({x, y, pressure})
        State->>State: renderCurrentStroke()
        State->>DC: clearRect full canvas
        State->>DC: drawFreehandElements(ctx) — all existing freehand
        State->>DC: Draw current stroke segments

        loop For each point pair
            State->>DC: canvasToScreenLocal(p0), canvasToScreenLocal(p1)

            alt Pressure sensitivity enabled AND not highlighter
                State->>DC: lineWidth = baseWidth * (pressure * 1.5 + 0.3) * zoom
            else
                State->>DC: lineWidth = baseWidth * zoom
            end

            State->>DC: ctx.beginPath(), moveTo, lineTo, stroke
        end

        DC-->>User: Live ink trail on canvas
    end

    User->>DC: pointerup
    DC->>State: onDrawUp(event)

    alt points.length > 1
        State->>State: pushUndo()

        opt penSmoothing enabled AND points.length > 4
            State->>Smooth: smoothPoints(points, tension=0.5)
            Smooth-->>State: Smoothed points array (Catmull-Rom)
        end

        State->>State: Create freehand element
        Note over State: {id, type:"freehand", points, stroke, strokeWidth,<br/>opacity, mode, x, y, width, height (bounding box)}
        State->>State: elements.push(freehandElement)
        State->>State: saveData()
    else Single point (click without drag)
        State->>State: Discard stroke
    end

    State->>State: _currentStroke = null
    State->>DC: renderFreehandStrokes() — redraw all freehand elements
    DC-->>User: Final smoothed stroke on canvas


%% === Sequence Diagram — Portal SSO + Firestore Sync ===
sequenceDiagram
    participant Portal as BSI Portal
    participant Frame as ForgeBoard (iframe)
    participant State as App State
    participant FB as Firebase
    participant FS as Firestore

    Portal->>Frame: postMessage({type:"admin-auth", firebaseConfig, projects, sso})
    Frame->>State: setupSSO() message handler

    State->>State: Extract firebaseConfig, projects[], sso user
    State->>FB: initFirebaseIfNeeded(config)
    FB-->>State: firebase.initializeApp() done
    State->>FB: firebase.firestore()
    FB-->>State: db instance

    State->>State: currentUser = {uid, email, name, role}
    State->>State: projects = projects[]
    State->>State: renderProjectSelector()
    State-->>Portal: (ready)

    Portal->>Frame: postMessage({type:"active-project", projectId:"proj-123"})
    Frame->>State: switchProject("proj-123")

    opt Save current project boards first
        State->>FS: old project docRef.set({boards, activeBoardId, updatedAt})
        FS-->>State: Saved
        State->>State: localStorage backup
    end

    State->>State: activeProjectId = "proj-123"
    State->>State: Clear boards, elements, activeBoardId

    State->>FS: db.collection("projects").doc("proj-123").collection("forgeboard").doc("state").get()
    FS-->>State: Document snapshot

    alt Document exists
        State->>State: boards = snapshot.boards
        State->>State: activeBoardId = snapshot.activeBoardId
        State->>State: switchBoard(activeBoardId)
        State->>State: render()
    else No document
        State->>State: createBoard("Untitled Board")
        State->>State: render()
    end

    Note over State: Set up real-time listener

    State->>FS: docRef.onSnapshot(callback)

    loop Real-time sync
        FS-->>State: onSnapshot triggered (remote change)
        State->>State: Check hasPendingWrites (skip own writes)
        State->>State: Check updatedAt > lastFirestoreUpdate
        alt Remote update is newer
            State->>State: boards = remote.boards
            State->>State: elements = activeBoard.elements
            State->>State: viewport = activeBoard.viewport
            State->>State: render()
            State-->>Portal: Canvas updated with remote changes
        end
    end

    Note over State: Periodic auto-save every 2s

    loop Auto-save interval
        State->>State: _flushSave()
        State->>State: localStorage.setItem(backup)
        State->>FS: docRef.set({boards, activeBoardId, updatedAt}, merge:false)
        FS-->>State: Saved
    end


